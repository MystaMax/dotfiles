# appearance
cursor-style = block
cursor-style-blink = false
font-family = JetBrainsMono Nerd Font Mono
font-size = 16
font-thicken = true
macos-titlebar-style = hidden
theme = mysta
window-theme = auto

# keybinds
keybind = cmd+shift+,=reload_config
keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = cmd+b=esc:b
keybind = cmd+f=esc:f
keybind = cmd+period=esc:.
# Home/End also configured via Karabiner on macOS
# keybind = cmd+left=text:\x1bOH
# keybind = cmd+right=text:\x1bOF
keybind = cmd+backspace=text:\x1b\x7f
keybind = super+t=unbind
keybind = super+n=unbind

# Map shift+enter to the same bytes as option+enter (ESC + CR).
# Reason: tmux 3.5a can't distinguish shift+enter from plain enter
# without the kitty keyboard protocol (which tmux doesn't support),
# so TUIs like Copilot CLI / Claude Code / Gemini CLI can't use
# shift+enter for multiline newlines while running inside tmux.
# Rewriting at Ghostty bypasses tmux entirely. Outside tmux, the
# remap is a harmless no-op (every modern TUI treats meta+enter and
# shift+enter the same way: insert a newline).
keybind = shift+enter=text:\x1b\r

# behavior
copy-on-select = true
quick-terminal-position = top
confirm-close-surface = false
quit-after-last-window-closed = true
shell-integration-features = sudo
